# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/elearning
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/elearning
MONGODB_URI=mongodb://127.0.0.1:27017/elearning

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_SECURE_RANDOM_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_SECURE_RANDOM_64_BYTE_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ─── Sentry (optional — leave blank to skip initialisation) ───────────────────
